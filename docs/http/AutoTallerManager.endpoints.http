  "name": "Supplier {{unique}}",
  "taxId": "TAX-{{unique}}",
  "phone": "6071234567",
  "email": "supplier{{unique}}@mail.com",
  "isActive": true
}

### 
POST {{baseUrl}}/api/partpurchases
