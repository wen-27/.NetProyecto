### RECEPTIONIST - personas, contacto, vehiculos y propietarios
POST {{baseUrl}}/api/persons
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "firstNames": "Persona Test",
  "lastNames": "Smoke"
}

### 
POST {{baseUrl}}/api/personemails
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "personId": {{personId}},
  "emailDomainId": 1,
  "emailUser": "persona{{unique}}",
  "isPrimary": true
}

### 
POST {{baseUrl}}/api/personphones
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "personId": {{personId}},
  "countryId": 1,
  "phoneNumber": "310{{unique}}",
  "isPrimary": true
}

### ADMIN - marcas y modelos
POST {{baseUrl}}/api/vehiclebrands
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "brandName": "Test Brand {{unique}}"
}

### 
POST {{baseUrl}}/api/vehiclemodels
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "brandId": 1,
  "modelName": "Test Model {{unique}}"
}

### 
POST {{baseUrl}}/api/vehicletypes
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "name": "Test Vehicle Type {{unique}}"
}

### RECEPTIONIST - crear vehiculo
POST {{baseUrl}}/api/vehicles
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "modelId": 1,
  "vehicleTypeId": 1,
  "vin": "TESTVIN{{unique}}",
  "year": 2026,
  "color": "Blue",
  "mileage": 1000,
  "isActive": true
}

### RECEPTIONIST - registrar propietario actual
POST {{baseUrl}}/api/vehicleownerhistory
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "vehicleId": {{vehicleId}},
  "personId": {{personId}},
  "startDate": "2026-01-01"
}

### RECEPTIONIST - terminar propiedad
PATCH {{baseUrl}}/api/vehicleownerhistory/{{vehicleId}}/end
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "endDate": "2026-05-27T00:00:00"
}

### ADMIN - servicios y estados
POST {{baseUrl}}/api/servicetypes
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "name": "Test Service {{unique}}",
  "estimatedDays": 2
}

### 
POST {{baseUrl}}/api/orderstatuses
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "name": "Test Status {{unique}}"
}

### RECEPTIONIST - crear orden de servicio
POST {{baseUrl}}/api/serviceorders
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "vehicleId": {{vehicleId}},
  "orderStatusId": 1,
  "estimatedDeliveryDate": "2026-05-30T10:00:00",
  "generalDescription": "Smoke test service order"
}

### ADMIN - crear linea de servicio
POST {{baseUrl}}/api/orderservices
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "serviceOrderId": {{serviceOrderId}},
  "serviceTypeId": 1,
  "description": "Diagnostics",
  "laborCost": 75000
}

### RECEPTIONIST/ADMIN - asignar mecanico a linea
POST {{baseUrl}}/api/mechanicassignments
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "orderServiceId": {{orderServiceId}},
  "mechanicPersonId": {{personId}},
  "specialtyId": 1
}

### MECHANIC - registrar trabajo realizado
PATCH {{baseUrl}}/api/serviceorders/{{serviceOrderId}}/work
Authorization: Bearer {{mechanicToken}}
Content-Type: {{json}}

{
  "workPerformed": "Diagnostico y revision general completados."
}

### MECHANIC - cambiar estado
PATCH {{baseUrl}}/api/serviceorders/{{serviceOrderId}}/status
Authorization: Bearer {{mechanicToken}}
Content-Type: {{json}}

{
  "orderStatusId": 2,
  "userId": {{userId}},
  "observation": "Orden en proceso"
}

### ADMIN - inventario
POST {{baseUrl}}/api/partcategories
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "name": "Test Category {{unique}}"
}

### 
POST {{baseUrl}}/api/partbrands
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "name": "Test Part Brand {{unique}}"
}

### 
POST {{baseUrl}}/api/parts
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "partCategoryId": 1,
  "partBrandId": null,
  "code": "PART-{{unique}}",
  "description": "Smoke test part",
  "stock": 20,
  "minimumStock": 5,
  "unitPrice": 45000,
  "isActive": true
}

### MECHANIC - agregar repuesto a linea de servicio
POST {{baseUrl}}/api/orderserviceparts
Authorization: Bearer {{mechanicToken}}
Content-Type: {{json}}

{
  "orderServiceId": {{orderServiceId}},
  "partId": {{partId}},
  "quantity": 1,
  "appliedUnitPrice": 45000
}

### MECHANIC - actualizar repuesto de linea
PUT {{baseUrl}}/api/orderserviceparts/{{id}}
Authorization: Bearer {{mechanicToken}}
Content-Type: {{json}}

{
  "quantity": 2,
  "appliedUnitPrice": 45000,
  "customerApproved": true,
  "approvalDate": "2026-05-27T10:00:00"
}

### MECHANIC - generar factura
POST {{baseUrl}}/api/invoices
Authorization: Bearer {{mechanicToken}}
Content-Type: {{json}}

{
  "serviceOrderId": {{serviceOrderId}},
  "invoiceStatusId": 1
}

