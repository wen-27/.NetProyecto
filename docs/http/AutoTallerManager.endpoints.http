}

### 
POST {{baseUrl}}/api/partpurchasedetails
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "partPurchaseId": 1,
  "partId": {{partId}},
  "quantity": 2,
  "unitPrice": 45000
}

### 
POST {{baseUrl}}/api/payments
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "invoiceId": {{invoiceId}},
  "paymentMethodId": 1,
  "paymentStatusId": 1,
  "amount": 120000,
  "reference": "PAY-{{unique}}"
}

### 
POST {{baseUrl}}/api/paymentcards
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "paymentId": 1,
  "cardTypeId": 1,
  "lastFourDigits": "1234",
  "cardHolder": "Smoke Test",
  "authorizationCode": "AUTH-{{unique}}"
}

### ADMIN - auditoria manual
POST {{baseUrl}}/api/audits
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "userId": {{userId}},
  "auditActionTypeId": 1,
  "affectedEntity": "SmokeTest",
  "affectedRecordId": 1,
  "description": "Manual audit smoke test"
}

### ADMIN - crear usuario manual
POST {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "personId": {{personId}},
  "passwordHash": "$2a$11$replaceWithRealHashIfTestingCreateUser"
}

### ADMIN - activar/desactivar usuario
PATCH {{baseUrl}}/api/users/{{userId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "status": true
}

### ADMIN - asignar rol a usuario
POST {{baseUrl}}/api/userroles
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "userId": {{userId}},
  "roleId": {{roleId}}
}

### ADMIN - consultar rol compuesto
GET {{baseUrl}}/api/userroles/{{userId}}/{{roleId}}
Authorization: Bearer {{adminToken}}

### ADMIN - quitar rol a usuario
DELETE {{baseUrl}}/api/userroles?userId={{userId}}&roleId={{roleId}}
Authorization: Bearer {{adminToken}}

### UPDATE SMOKE - ejemplos
PUT {{baseUrl}}/api/vehicles/{{vehicleId}}
Authorization: Bearer {{receptionistToken}}
Content-Type: {{json}}

{
  "modelId": 1,
  "vehicleTypeId": 1,
  "vin": "TESTVINUPDATE01",
  "year": 2026,
  "color": "Black",
  "mileage": 2000,
  "isActive": true
}

### 
PUT {{baseUrl}}/api/parts/{{partId}}
Authorization: Bearer {{adminToken}}
Content-Type: {{json}}

{
  "partCategoryId": 1,
  "partBrandId": null,
  "code": "PART-UPDATE-{{unique}}",
  "description": "Updated smoke part",
  "stock": 15,
  "minimumStock": 5,
  "unitPrice": 50000,
  "isActive": true
}

### DELETE/GUARD SMOKE - esperado 204 si no tiene dependencias activas; 400/409 si guard lo bloquea
DELETE {{baseUrl}}/api/persons/{{personId}}
Authorization: Bearer {{adminToken}}

### 
DELETE {{baseUrl}}/api/vehicles/{{vehicleId}}
Authorization: Bearer {{adminToken}}

### 
DELETE {{baseUrl}}/api/orderserviceparts/{{id}}
Authorization: Bearer {{mechanicToken}}
